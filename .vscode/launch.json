{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "App: X-Ray-HC",
            "type": "debugpy",
            "request": "launch",
            "module": "x_ray",
            "console": "integratedTerminal",
            "justMyCode": true,
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/src",
                    "remoteRoot": "${workspaceFolder}/src"
                }
            ],
            "args": [
                "hc",
                "-s",
                "default",
                "mongodb://localhost:27017/admin?tls=false&connectTimeoutMS=5000",
                // "mongodb://localhost:27027/admin?tls=false&connectTimeoutMS=5000",
                // "mongodb+srv://cluster0.wy1z6.mongodb.net/?appName=Cluster0"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "LOG_LEVEL": "INFO",
                "ENV": "development"
            }
        },
        {
            "name": "App: X-Ray-LOG",
            "type": "debugpy",
            "request": "launch",
            "module": "x_ray",
            "console": "integratedTerminal",
            "justMyCode": true,
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/src",
                    "remoteRoot": "${workspaceFolder}/src"
                }
            ],
            "args": [
                "-c",
                "src/x_ray/config.json",
                "log",
                "-r",
                "1",
                "misc/example.log",
                
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "LOG_LEVEL": "INFO",
                "ENV": "development"
            }
        },
        {
            "name": "App: X-Ray-GMD",
            "type": "debugpy",
            "request": "launch",
            "module": "x_ray",
            "console": "integratedTerminal",
            "justMyCode": true,
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/src",
                    "remoteRoot": "${workspaceFolder}/src"
                }
            ],
            "args": [
                "-c",
                "src/x_ray/config.json",
                "gmd",
                "misc/getMongoData-output.json"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "LOG_LEVEL": "INFO",
                "ENV": "development"
            }
        },
        {
            "name": "App: X-Ray-FTDC",
            "type": "debugpy",
            "request": "launch",
            "module": "x_ray",
            "console": "integratedTerminal",
            "justMyCode": true,
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/src",
                    "remoteRoot": "${workspaceFolder}/src"
                }
            ],
            "args": [
                "-c",
                "src/x_ray/config.json",
                "ftdc",
                "-f",
                "html",
                "misc/ftdc",
                "2026-05-19T00:00:00",
                "2026-05-19T06:00:00"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "LOG_LEVEL": "INFO",
                "ENV": "development"
            }
        },
        {
            "name": "Unit Test",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "console": "integratedTerminal",
            "args": [],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "LOG_LEVEL": "INFO",
                "ENV": "development"
            }
        }
    ]
}